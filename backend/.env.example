# Backend Environment Variables
# Copy this file to .env and fill in real values

# Internal service-to-service authentication token
INTERNAL_SERVICE_TOKEN=

# Cloudinary configuration for resume file uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT signing secret (minimum 256-bit base64-encoded key)
JWT_SECRET=

# Resend email provider (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@resumerank.ai

# Frontend URL for email verification and password reset links
FRONTEND_URL=http://localhost:3000
